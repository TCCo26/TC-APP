{
  "name": "life-os-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop launcher for the Work (Qualitech) and Personal (Jhabes) dashboards — opens each as its own native app window.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.tcco26.lifeosdesktop",
    "productName": "Life OS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "picker-preload.js",
      "static-server.js",
      "picker.html",
      "config.json",
      "build/icon.png",
      "apps/**/*"
    ],
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  }
}
